{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 31,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_CXX_STANDARD": "20",
                "CMAKE_CXX_STANDARD_REQUIRED": "ON",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "AVIUTL2_SDK_CPP_BUILD_EXAMPLES": "ON",
                "AVIUTL2_SDK_CPP_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "ninja",
            "displayName": "Ninja",
            "inherits": "base",
            "generator": "Ninja"
        },
        {
            "name": "vs",
            "displayName": "Visual Studio 2026",
            "inherits": "base",
            "generator": "Visual Studio 18 2026",
            "architecture": {
                "value": "x64",
                "strategy": "external"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "ninja",
            "displayName": "Build with Ninja",
            "configurePreset": "ninja"
        },
        {
            "name": "vs",
            "displayName": "Build with Visual Studio 2026",
            "configurePreset": "vs"
        }
    ],
    "testPresets": [
        {
            "name": "ninja",
            "displayName": "Test with Ninja",
            "configurePreset": "ninja"
        },
        {
            "name": "vs",
            "displayName": "Test with Visual Studio 2026",
            "configurePreset": "vs"
        }
    ]
}
